# Reddit API
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=reddit-feed-digest/1.0

# Gemini API
GOOGLE_API_KEY=your_google_api_key

# Optional post-render publish command.
# The generated HTML path will be available as REPORT_FILE.
# Example:
# PUBLISH_COMMAND=./scripts/publish_report.sh
PUBLISH_COMMAND=

# Admin UI auth (optional)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
